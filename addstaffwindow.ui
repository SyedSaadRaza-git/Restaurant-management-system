   <property name="styleSheet">
    <string notr="true">#StaffPositionlineEdit {
    background-color:  transparent; /* Set the background color */
    border:  transparent; /* Match the border color to the background (invisible) */
    color: black; /* Text color (adjust as needed) */
    border-radius: 5px; /* Optional: Rounded corners */
    padding: 5px; /* Optional: Add inner padding for better spacing */
}

#StaffPositionlineEdit:focus {
    outline: none; /* Remove focus outline if any */
    border:  transparent; /* Slightly different color for focus state (optional) */
}</string>
   </property>
   <property name="placeholderText">
    <string>Enter Position</string>
