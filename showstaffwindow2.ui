   <property name="styleSheet">
    <string notr="true">#showAllButton {
    background-color: transparent; /* Fully transparent background */
    border: none; /* No visible border */
    border-radius: 50%; /* Circular button */
    width: 50px; /* Fixed width */
    height: 50px; /* Fixed height */
}

#showAllButton:hover {
    background-color: rgba(255, 0, 0, 0.1); /* Slight red tint on hover */
}

#showAllButton:pressed {
    background-color: rgba(255, 0, 0, 0.2); /* Slightly brighter red tint on click */
}</string>
